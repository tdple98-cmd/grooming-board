# Copy to .env.local (gitignored). Do not commit secrets.
#
# Local Square testing:
#   npx vercel link
#   npx vercel env run -e production -- npm run test:square
#   npx vercel env run -e production -- npm run sync:square
#   npx vercel env run -e production -- npm run dev:api
#
# If production secrets won't pull, ask client to duplicate vars into Vercel "Development"
# then: npx vercel env pull .env.local --environment=development

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_public_key_here

# Due-to-rebook: weeks after last groom before a pet appears overdue (all services).
# Example: 6 = show in Due to rebook 6 weeks after last visit. Set in Vercel → Environment Variables.
VITE_REBOOK_WEEKS=6

SQUARE_ACCESS_TOKEN=
SQUARE_ENVIRONMENT=production
SQUARE_APPLICATION_ID=
SUPABASE_SERVICE_ROLE_KEY=

SQUARE_SYNC_DAYS=7
CRON_SECRET=
