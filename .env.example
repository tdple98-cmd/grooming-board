# Copy this file to .env.local and replace with real values.
# Do NOT commit .env.local — it is gitignored.
#
# Local dev: edit .env.local directly. Do NOT run `vercel env pull` — it
# overwrites your local file with empty Vercel placeholders.

# Frontend (Vite)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_public_key_here

# Server-side only (Square sync API + local scripts — never VITE_ prefix)
SQUARE_ACCESS_TOKEN=
SQUARE_ENVIRONMENT=sandbox
SQUARE_APPLICATION_ID=
SUPABASE_SERVICE_ROLE_KEY=

# Sync window: today + next 6 days (7 Melbourne calendar days). Past Supabase rows are kept.
SQUARE_SYNC_DAYS=7

# Automated sync (Vercel Cron twice daily + optional Supabase pg_cron)
CRON_SECRET=
