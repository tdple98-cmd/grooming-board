{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" }
  ],
  "functions": {
    "api/square/sync.js": {
      "maxDuration": 300
    }
  },
  "crons": [
    {
      "path": "/api/square/sync",
      "schedule": "0 20 * * *"
    },
    {
      "path": "/api/square/sync",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/square/sync?mode=history",
      "schedule": "0 19 * * *"
    },
    {
      "path": "/api/owner/nightly-digest",
      "schedule": "0 11 * * *"
    }
  ]
}
