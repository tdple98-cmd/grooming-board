{
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" }
  ],
  "crons": [
    {
      "path": "/api/square/sync",
      "schedule": "0 20 * * *"
    },
    {
      "path": "/api/square/sync",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/square/sync?mode=history",
      "schedule": "0 19 * * *"
    }
  ]
}
